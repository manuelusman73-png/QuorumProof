{
  "title": "Credential Volume",
  "uid": "qp-credential-volume",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Credentials Issued / Hour",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(quorumproof_credentials_issued_total[1h])",
          "legendFormat": "issued/hr"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 2,
      "title": "Credentials Revoked / Hour",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(quorumproof_credentials_revoked_total[1h])",
          "legendFormat": "revoked/hr"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 3,
      "title": "Cumulative Credentials",
      "type": "stat",
      "targets": [
        {
          "expr": "quorumproof_credentials_issued_total",
          "legendFormat": "total"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 }
    },
    {
      "id": 4,
      "title": "Active Slices",
      "type": "stat",
      "targets": [
        {
          "expr": "quorumproof_active_slices_total",
          "legendFormat": "slices"
        }
      ],
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 }
    }
  ]
}
