{
  "title": "Attestation Health",
  "uid": "qp-attestation-health",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Attestation Success Rate",
      "type": "gauge",
      "targets": [
        {
          "expr": "quorumproof_attestation_success_rate",
          "legendFormat": "success rate"
        }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 1, "unit": "percentunit" }
      },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 8 }
    },
    {
      "id": 2,
      "title": "Attestations / Hour",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(quorumproof_attestations_total[1h])",
          "legendFormat": "attestations/hr"
        }
      ],
      "gridPos": { "x": 6, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 3,
      "title": "Error Trends by Code",
      "type": "barchart",
      "targets": [
        {
          "expr": "sum by (error_code) (rate(quorumproof_api_errors_total[1h]))",
          "legendFormat": "{{error_code}}"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "id": 4,
      "title": "Fork Detections",
      "type": "stat",
      "targets": [
        {
          "expr": "quorumproof_api_errors_total{error_code=\"34\"}",
          "legendFormat": "forks"
        }
      ],
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 }
    }
  ]
}
